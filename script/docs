#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"

echo "==> prepare docs output"
rm -rf docs/_site
mkdir -p docs/_site

echo "==> generate DocC site"
swift package --allow-writing-to-directory docs/_site \
  generate-documentation \
  --target WorkOS \
  --disable-indexing \
  --transform-for-static-hosting \
  --hosting-base-path workos-ios \
  --output-path docs/_site

echo "==> write root redirect to documentation landing page"
cat > docs/_site/index.html <<'HTML'
<!doctype html>
<meta charset="utf-8">
<meta http-equiv="refresh" content="0; url=documentation/workos/">
<link rel="canonical" href="documentation/workos/">
<title>WorkOS iOS Documentation</title>
HTML
